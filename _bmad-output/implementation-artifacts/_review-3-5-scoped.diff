diff --git a/api/_lib/createPaymentIntentBody.ts b/api/_lib/createPaymentIntentBody.ts
new file mode 100644
index 0000000..f9c1781
--- /dev/null
+++ b/api/_lib/createPaymentIntentBody.ts
@@ -0,0 +1,52 @@
+import { z } from "zod";
+
+/** One checkout line; `quantity` is the public Epic 3 field (mirrors `checkoutLineDraftSchema`). */
+export const paymentIntentLineItemSchema = z.object({
+  sku: z.string().min(1),
+  quantity: z.number().int().positive(),
+  variant_id: z.string().uuid().optional(),
+  product_slug: z.string().min(1).optional(),
+});
+
+export type PaymentIntentLineItem = z.infer<typeof paymentIntentLineItemSchema>;
+
+/**
+ * POST /api/create-payment-intent body. When `items` is non-empty, `amount` is ignored for pricing (AC 3-3).
+ */
+export const createPaymentIntentBodySchema = z
+  .object({
+    items: z.array(paymentIntentLineItemSchema).optional(),
+    /** Ignored when `items` has at least one line (server computes amount). */
+    amount: z.number().optional(),
+    currency: z.string().min(1).optional(),
+    email: z.preprocess(
+      (v) => (v === "" || v == null ? undefined : v),
+      z.string().email().optional()
+    ),
+  })
+  .superRefine((data, ctx) => {
+    const hasItems = (data.items?.length ?? 0) > 0;
+    const amount = data.amount;
+    if (!hasItems && (amount == null || !Number.isFinite(amount) || Math.floor(amount) < 1)) {
+      ctx.addIssue({
+        code: "custom",
+        message: "No items or amount",
+        path: ["amount"],
+      });
+    }
+  })
+  .transform((data) => ({
+    ...data,
+    currency: data.currency && data.currency.length > 0 ? data.currency : "usd",
+  }));
+
+export type CreatePaymentIntentBody = z.infer<typeof createPaymentIntentBodySchema>;
+
+export function parseCreatePaymentIntentBody(raw: unknown): CreatePaymentIntentBody {
+  return createPaymentIntentBodySchema.parse(raw);
+}
+
+/** Map validated lines to `computeAmountCents` / catalog input (`qty`). */
+export function lineItemsToCatalogRows(items: PaymentIntentLineItem[]): Array<{ sku: string; qty: number }> {
+  return items.map((l) => ({ sku: l.sku, qty: l.quantity }));
+}
