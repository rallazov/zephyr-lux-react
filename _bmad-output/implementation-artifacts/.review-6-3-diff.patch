+    fireEvent.change(screen.getByTestId("pdp-select-size"), {
+      target: { value: "S" },
+    });
+
+    const main = await screen.findByTestId("pdp-gallery-main");
+    await waitFor(() => {
+      expect(main).toHaveAttribute("src", "/primary-s.jpg");
+    });
+
+    fireEvent.change(screen.getByTestId("pdp-select-size"), {
+      target: { value: "M" },
+    });
+
+    await waitFor(() => {
+      expect(main).toHaveAttribute("src", "/primary-m.jpg");
+    });
+  });
+});
