+          <p style={{ marginBottom: 16, color: "#333" }}>
+            There are no products available right now.
+          </p>
+          <Link
+            to="/"
+            style={{ color: "#1a1a1a", textDecoration: "underline" }}
+          >
+            Return home
+          </Link>
+        </div>
+      )}
+      {!loadError && products.length > 0 && (
+        <CatalogProductGrid products={products} />
+      )}
     </div>
   );
 };
